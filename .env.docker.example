# ===========================================================================
# Variáveis opcionais para o docker compose (copie para `.env` na raiz).
# Todos os valores têm padrão embutido no docker-compose.yml; defina aqui
# apenas o que quiser sobrescrever — em produção, TROQUE os segredos JWT.
# ===========================================================================

# Credenciais do PostgreSQL
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=farmasystem

# MongoDB (GridFS)
MONGO_DB=farmasystem_files

# Segredos JWT (gere valores fortes: ex. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_REFRESH_EXPIRES_IN=7d

# URLs públicas (acessadas pelo navegador)
FRONTEND_ORIGIN=http://localhost:3001
APP_PUBLIC_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
